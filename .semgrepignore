# Files Semgrep should not scan. Mirrors gitignore-style globs.
#
# Keep this list aligned with the --exclude flags in
# .github/workflows/semgrep.yml so local runs and CI agree.

# Virtualenvs and tool caches — never our code
.venv/
__pycache__/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Tests intentionally include anti-patterns (mock secrets, deliberately
# vulnerable inputs, etc.) and Semgrep flags those as findings.
tests/

# Generated migrations — autogenerated by alembic, not hand-written.
alembic/versions/

# Rendered docs
docs/
